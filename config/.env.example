# Core runtime
NODE_ENV=development
VINKOCLAW_HOST=0.0.0.0
VINKOCLAW_PORT=8098
VINKOCLAW_PUBLIC_URL=http://127.0.0.1:8098
VINKOCLAW_DATA_DIR=/home/xsuper/workspace/vinkoclaw/.data
VINKOCLAW_WORKSPACE_ROOT=/home/xsuper/workspace

# Model backend (local or external OpenAI-compatible API)
PRIMARY_BACKEND=sglang
PRIMARY_MODEL=Qwen3.5-35B-A3B
SGLANG_BASE_URL=http://127.0.0.1:8000/v1
SGLANG_MODEL=Qwen3.5-35B-A3B
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=qwen3.5-instruct-14b
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1
DASHSCOPE_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
DASHSCOPE_MODEL=qwen3.6-plus

# Tool execution (opencode + custom OpenAI-compatible provider)
VINKOCLAW_OPENCODE_MODEL=zhipuai/glm-5
VINKOCLAW_OPENCODE_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPUAI_API_KEY=
DASHSCOPE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Feishu
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_DOMAIN=feishu
FEISHU_CONNECTION_MODE=websocket
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=
FEISHU_DEFAULT_CHAT_ID=
FEISHU_OWNER_OPEN_IDS=

# Email
SMTP_URL=
EMAIL_DEFAULT_FROM=
EMAIL_INBOUND_ENABLED=0
EMAIL_INBOUND_IMAP_HOST=imap.qq.com
EMAIL_INBOUND_IMAP_PORT=993
EMAIL_INBOUND_IMAP_SECURE=1
EMAIL_INBOUND_USERNAME=
EMAIL_INBOUND_PASSWORD=
EMAIL_INBOUND_MAILBOX=INBOX
EMAIL_INBOUND_ALLOWED_SENDERS=
EMAIL_INBOUND_SUBJECT_PREFIX=[VinkoTask]
EMAIL_INBOUND_POLL_INTERVAL_MS=15000
EMAIL_INBOUND_RATE_LIMIT_PER_MINUTE=20

# Recurring workflows
RECURRING_RUNNER_ENABLED=0
RECURRING_RUNNER_INTERVAL_MS=300000

# Optional command/network helpers
USE_CLASH_PROXY=0
CLASH_ON_COMMAND=clashon
CLASH_OFF_COMMAND=clashoff
VINKO_SKILL_REGISTRY_URL=

# Python environment
CONDA_ENV_NAME=vinkoclaw
